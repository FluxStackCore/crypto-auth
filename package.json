{
  "name": "@fluxstack/plugin-crypto-auth",
  "version": "1.0.0",
  "description": "Ed25519 cryptographic authentication plugin for FluxStack - zero sessions, private key stays in browser",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./config": "./config/index.ts",
    "./client": "./client/index.ts",
    "./server": "./server/index.ts",
    "./server/*": "./server/*.ts",
    "./cli/*": "./cli/*.ts"
  },
  "keywords": [
    "fluxstack",
    "plugin",
    "authentication",
    "ed25519",
    "cryptography",
    "zero-session"
