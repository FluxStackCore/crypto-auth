  "peerDependencies": {
    "@fluxstack/config": "^1.0.0",
    "@fluxstack/live": "^0.5.0",
    "@noble/curves": "^1.2.0",
    "@noble/hashes": "^1.3.0",
    "elysia": "^1.4.0"
  },
  "devDependencies": {
    "@noble/curves": "1.2.0",
    "@noble/hashes": "1.3.2",
    "@types/node": "^25.5.2",
    "vitest": "^3.2.4"
  }
