{
  "name": "@fluxstack/sdk",
  "version": "1.0.0",
  "description": "SDK for building FluxStack plugins — types, config helpers, and env utilities",
  "type": "module",
  "main": "index.ts",
  "types": "index.ts",
  "exports": {
    ".": {
      "bun": "./index.ts",
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./config": {
      "bun": "./config.ts",
      "types": "./config.ts",
      "default": "./config.ts"
    },
    "./env": {
      "bun": "./env.ts",
      "types": "./env.ts",
      "default": "./env.ts"
    }
  },
  "files": ["dist", "*.ts"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "bun run build"
  },
  "keywords": ["fluxstack", "sdk", "types", "config"],
  "author": "FluxStack Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
